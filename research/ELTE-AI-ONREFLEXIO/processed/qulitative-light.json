{
    "ai_concerns": [
        {
            "fieldKey": "ai_concerns",
            "text": "A gondolkodás készségének elvesztése",
            "id": 1,
            "tags": [
                "dependence",
                "concerned",
                "cognitive_loss"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Az uniformizáció, mindenkinek hasonló gondolatokat és megfogalmazásokat ültet el a fejében",
            "id": 24,
            "tags": [
                "uniformization",
                "concerned",
                "societal_homogenization"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "a túlzottan megerősítő enabling hozzáállás ami jellemző rá",
            "id": 24,
            "tags": [
                "enabling",
                "dependence",
                "critical_thinking_loss"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": " illetve a környezetvédelmi szempontok.",
            "id": 24,
            "tags": [
                "environmental"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Ez lehet butaság, de egy időben kifejezetten kerültem, hogy adatot adjak meg magamról, illetve a hangomat sem rögzítettem vele. Idővel előfordulhat ilyen jellegű visszaélés akár a személyiséggel is. Jelenleg ugye adathalászat többféle formája működik. Ha túl sokat használtam, felmerült hogy nem döntök addig, míg át nem beszéltem vele. Ez már káros. Túl sok idő el tud menni mélyebb fejtegetésekkel. Előfordul hogy csak azt dobja vissza javaslatnak, amit már írtam, így ki tud esni perspektíva.",
            "id": 31,
            "tags": [
                "privacy",
                "dependence",
                "decision_paralysis"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Az AI, ha nem jó promptot fogalmazol meg, akkor úgyis azt mondja, amit hallani szeretnél: mindig igazat ad neked, mindig validál stb. Ez egy ponton már lehet káros is, ugyanis nem elég ha folyamatosan nyaliznak meg babusgatnak, hanem igenis ki kell mondani sokszor a nyers igazságot",
            "id": 36,
            "tags": [
                "sycophancy",
                "dependence",
                "critical_feedback_absence"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Az hogy bizonyos dolgokban emberek korlátozzák pl gyógyszer adagolása tanácsok vagy egyéb anyagok adagolása terén",
            "id": 37,
            "tags": [
                "dependence",
                "over_reliance",
                "medical"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "átlagolás, nehezen tud értelmezni specifikus helyzeteket",
            "id": 44,
            "tags": [
                "limitations",
                "generic",
                "context_blindness"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Pontosabban magam miatt nem aggódom, de a tágabb társadalomra nézve vannak veszélyek",
            "id": 57,
            "tags": [
                "society",
                "positive",
                "self_aware"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Azt gondolom, hogy mivel tudom, hogy másodrangú információként, plusz eszközként használom, egész tudatosan kezelem. Néha észreveszem, hogy túl általános vagy fáraszt a válasza..",
            "id": 67,
            "tags": [
                "limitations",
                "generic",
                "self_aware",
                "positive"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Bizonyára elképesztően sok energiát fogyaszt, tehát magas az ára, csak azt nem mi fizetjük közvetlenül. Nem transzparens eléggé a működése ilyen szempontból. És ez aggasztó, hogy vajon mekkora energiaválságot okozhat hosszútávon az, ha a cégek/országok majd a szerverparkok fenntartására fókuszálnak jobban, mint a lakosság valós igényeire (pl. hogy legyen ivóvíz).",
            "id": 80,
            "tags": [
                "environmental",
                "infrastructure_risk",
                "dependence",
                "systemic_risk"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Elbutulás, smart funkciók outsourcolása",
            "id": 96,
            "tags": [
                "dependence"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Nem igazán lehet kikapcsolni benne a felszopó üzemmódot.",
            "id": 97,
            "tags": [
                "sycophancy"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "túl gyors validáció vagy épp túlelemző spirál, cselekvés illúziója, túl erős hatás a hangulatomra",
            "id": 104,
            "tags": [
                "dependence",
                "validation_seeking",
                "mood_influence",
                "decision_paralysis",
                "action_illusion"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Csak az én szemszögemet ismeri egy konfliktus kapcsán, és emiatt egy kicsit részrehajló, nem kérdőjelezi meg az én megélésemet… egyelőre",
            "id": 117,
            "tags": [
                "dependence",
                "sycophancy",
                "limitations",
                "one_sided_perspective"
            ]
        },
        {
            "fieldKey": "ai_concerns",
            "text": "Nem tudom, hogy az AI rólam gyűjtött információit hova menti el",
            "id": 120,
            "tags": [
                "privacy"
            ]
        }
    ],
